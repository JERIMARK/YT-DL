    printf "\e[032mEnter YouTube URL: $kill_color"
    read url

    if [[ -z $url ]]; then
        clear
        printf "\e[031mPlease enter a URL!\n$kill_color"
        sleep 2
        continue
    fi

    echo -e "\e[036mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—"
