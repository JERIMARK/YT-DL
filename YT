    echo -e "\e[036mв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—"
    echo -e "\e[032mв•‘ вҷҡ Tool Name : AZ                           в•‘"
    echo -e "\e[032mв•‘ вҷҡ Contributor : Azer                       в•‘"
    echo -e "\e[032mв•‘ вҷҡ GitHub : https://github.com/JERIMARK     в•‘"
    echo -e "\e[032mв•‘ вҷҡ YouTube : www.youtube.com/@azerrrr       в•‘"
